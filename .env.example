# Postgres da Vercel/Neon
# pooled (pgbouncer) — runtime
DATABASE_URL=
# direta (sem pooler) — migrations
DATABASE_URL_UNPOOLED=

# gere com: npx auth secret
AUTH_SECRET=

# senha única compartilhada do bolão
SENHA_BOLAO=copa2026

# token gratuito do football-data.org
FOOTBALL_DATA_TOKEN=

# string aleatória pra proteger o endpoint do cron de apuração
CRON_SECRET=

# (opcional) corte de pontuação em ISO UTC. Vazio = deriva do 1º jogo da 2ª rodada
PONTUACAO_INICIA_EM=
# (opcional) "true" oculta no histórico os jogos que não valem pontos
OCULTAR_JOGOS_SEM_PONTOS=false
